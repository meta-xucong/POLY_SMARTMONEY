{
  "extends": "screen_users_config.json",
  "_comment_extends": "Actionable override config focused on recent, still-tradable political-market accounts",

  "use_official_market_category": true,
  "official_political_categories": [
    "politics",
    "political",
    "election"
  ],

  "recent_window_days": 30,
  "max_users_to_scan": 5000,
  "official_category_lookup_user_limit": 3500,
  "official_category_lookup_condition_limit": 35000,
  "gamma_condition_ids_chunk_size": 40,
  "gamma_timeout_sec": 6,
  "gamma_request_retries": 1,
  "screen_progress_every_users": 50,
  "gamma_progress_every_chunks": 5,

  "filters": {
    "min_closed_count": 20,
    "min_account_age_days": 90,
    "min_lifetime_realized_pnl": 100,
    "min_political_condition_ratio": 0.30,
    "max_hedge_condition_ratio": 0.35,
    "min_stability_score": 0.32,
    "max_max_drawdown_ratio": 0.65,
    "max_pnl_top1_day_share": 0.55,
    "max_trades_per_day": 35,
    "max_daily_trades": 80,
    "min_bayes_win_rate": 0.51,
    "min_median_roi": 0.005,
    "max_tail_high_ratio": 0.75,
    "max_tail_low_ratio": 0.35,
    "min_mid_ratio": 0.10,
    "max_minute_burst_ratio": 0.35,
    "min_interval_median_minutes": 2,

    "min_recent_closed_count": 6,
    "min_recent_action_count": 12,
    "min_recent_condition_count": 5,
    "min_recent_active_days": 6,
    "min_recent_trades_per_day": 0.35,
    "min_recent_political_condition_ratio": 0.35,
    "min_leaderboard_month_pnl": 50,
    "max_last_trade_days_ago": 10
  },

  "score_weights": {
    "bayes_win_rate": 0.18,
    "median_roi": 0.10,
    "profit_factor": 0.08,
    "mid_ratio": 0.08,
    "interval_median_minutes": 0.06,
    "recent_closed_count": 0.10,
    "recent_action_count": 0.12,
    "recent_condition_count": 0.12,
    "recent_active_days": 0.10,
    "recent_trades_per_day": 0.08,
    "recent_political_condition_ratio": 0.10,
    "leaderboard_month_pnl": 0.08,
    "minute_burst_ratio": -0.08,
    "tail_high_ratio": -0.04,
    "tail_low_ratio": -0.05,
    "trades_per_day": -0.05,
    "burstiness": -0.04,
    "near_expiry_ratio": -0.04,
    "last_trade_days_ago": -0.12,
    "p90_cost": 0.0,
    "open_exposure": 0.0
  },

  "score_clamps": {
    "bayes_win_rate": 1.0,
    "median_roi": 1.0,
    "profit_factor": 10.0,
    "mid_ratio": 1.0,
    "interval_median_minutes": 120,
    "recent_closed_count": 30,
    "recent_action_count": 80,
    "recent_condition_count": 20,
    "recent_active_days": 20,
    "recent_trades_per_day": 3.0,
    "recent_political_condition_ratio": 1.0,
    "leaderboard_month_pnl": 2000,
    "minute_burst_ratio": 1.0,
    "tail_high_ratio": 1.0,
    "tail_low_ratio": 1.0,
    "trades_per_day": 40,
    "burstiness": 8,
    "near_expiry_ratio": 0.8,
    "last_trade_days_ago": 30,
    "p90_cost": 50000,
    "open_exposure": 300000
  },

  "stability_weight": 0.48,

  "label_rules": {
    "copy_style": {
      "minute_burst_ratio_high": 0.28,
      "interval_median_minutes_fast": 3,
      "trades_per_day_high": 25,
      "burstiness_high": 4,
      "near_expiry_ratio_high": 0.30
    }
  }
}
