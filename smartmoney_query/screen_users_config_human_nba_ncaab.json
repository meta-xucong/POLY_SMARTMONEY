{
  "extends": "screen_users_config.json",
  "_comment_extends": "Focused override config for NBA/NCAAB human-like profitable accounts",

  "use_official_market_category": true,
  "political_keywords": [
    "nba",
    "ncaab",
    "ncaa basketball",
    "college basketball",
    "basketball"
  ],
  "official_political_categories": [
    "nba",
    "ncaab",
    "basketball"
  ],

  "recent_window_days": 45,
  "max_users_to_scan": 5000,
  "official_category_lookup_user_limit": 5000,
  "official_category_lookup_condition_limit": 60000,
  "gamma_condition_ids_chunk_size": 40,
  "gamma_timeout_sec": 6,
  "gamma_request_retries": 1,
  "screen_progress_every_users": 50,
  "gamma_progress_every_chunks": 5,

  "filters": {
    "min_closed_count": 15,
    "min_account_age_days": 300,
    "min_lifetime_realized_pnl": 0,
    "min_political_condition_ratio": 0.55,
    "max_hedge_condition_ratio": 0.35,
    "min_stability_score": 0.25,
    "max_max_drawdown_ratio": 0.70,
    "max_pnl_top1_day_share": 0.65,
    "max_trades_per_day": 35,
    "max_daily_trades": 80,
    "min_bayes_win_rate": 0.51,
    "max_tail_high_ratio": 0.85,
    "max_tail_low_ratio": 0.60,
    "min_mid_ratio": 0.05,
    "max_minute_burst_ratio": 0.35,
    "min_interval_median_minutes": 1.5,

    "min_recent_closed_count": 4,
    "min_recent_action_count": 8,
    "min_recent_condition_count": 3,
    "min_recent_active_days": 4,
    "min_recent_trades_per_day": 0.15,
    "min_recent_political_condition_ratio": 0.50,
    "max_last_trade_days_ago": 30
  },

  "score_weights": {
    "bayes_win_rate": 0.20,
    "median_roi": 0.10,
    "profit_factor": 0.08,
    "mid_ratio": 0.06,
    "interval_median_minutes": 0.05,
    "recent_closed_count": 0.10,
    "recent_action_count": 0.12,
    "recent_condition_count": 0.10,
    "recent_active_days": 0.10,
    "recent_trades_per_day": 0.08,
    "recent_political_condition_ratio": 0.14,
    "minute_burst_ratio": -0.10,
    "tail_high_ratio": -0.04,
    "tail_low_ratio": -0.04,
    "trades_per_day": -0.08,
    "burstiness": -0.07,
    "near_expiry_ratio": -0.02,
    "last_trade_days_ago": -0.08,
    "p90_cost": 0.0,
    "open_exposure": 0.0
  },

  "score_clamps": {
    "bayes_win_rate": 1.0,
    "median_roi": 1.0,
    "profit_factor": 10.0,
    "mid_ratio": 1.0,
    "interval_median_minutes": 120,
    "recent_closed_count": 30,
    "recent_action_count": 80,
    "recent_condition_count": 20,
    "recent_active_days": 20,
    "recent_trades_per_day": 3.0,
    "recent_political_condition_ratio": 1.0,
    "minute_burst_ratio": 1.0,
    "tail_high_ratio": 1.0,
    "tail_low_ratio": 1.0,
    "trades_per_day": 40,
    "burstiness": 8,
    "near_expiry_ratio": 0.8,
    "last_trade_days_ago": 60,
    "p90_cost": 50000,
    "open_exposure": 300000
  },

  "stability_weight": 0.45,

  "final_output": {
    "sort_by": "copy_score",
    "descending": true
  }
}
